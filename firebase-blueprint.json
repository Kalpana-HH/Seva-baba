{
  "entities": {
    "Event": {
      "title": "Event",
      "description": "A scheduled gathering",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "guestsCount": { "type": "integer" },
        "theme": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "title", "type", "date", "time", "guestsCount", "description", "createdAt"]
    },
    "FoodItem": {
      "title": "FoodItem",
      "description": "A food item planned for a gathering",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "eventId": { "type": "string" },
        "name": { "type": "string" },
        "quantity": { "type": "string" },
        "category": { "type": "string" },
        "assignedTo": { "type": "string" },
        "status": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["id", "eventId", "name", "quantity", "category", "assignedTo", "status"]
    },
    "Task": {
      "title": "Task",
      "description": "A checkbox item or prep task for a gathering",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "eventId": { "type": "string" },
        "title": { "type": "string" },
        "timelineStage": { "type": "string" },
        "completed": { "type": "boolean" }
      },
      "required": ["id", "eventId", "title", "timelineStage", "completed"]
    }
  },
  "firestore": {
    "/events/{eventId}": {
      "schema": "Event",
      "description": "Private scheduled gatherings"
    },
    "/foods/{foodId}": {
      "schema": "FoodItem",
      "description": "Food items assigned per gathering"
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Checklist preparation tasks per gathering"
    }
  }
}
